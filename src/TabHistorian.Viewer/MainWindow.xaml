<Window x:Class="TabHistorian.Viewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TabHistorian.Viewer.ViewModels"
        Title="TabHistorian Viewer" Width="1000" Height="700"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search bar -->
        <TextBox Grid.Row="0" x:Name="SearchBox"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                 Padding="6" FontSize="14"
                 KeyDown="SearchBox_KeyDown">
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Style.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                        <VisualBrush.Visual>
                                            <TextBlock Text="  Search tabs, URLs, history..."
                                                       Foreground="Gray" FontSize="14" Margin="6,0,0,0"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>

        <!-- Snapshot filter -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,6">
            <TextBlock Text="Snapshot:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox x:Name="SnapshotCombo" Width="350"
                      ItemsSource="{Binding Snapshots}"
                      SelectedItem="{Binding SelectedSnapshot}"
                      Padding="4">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0}  ({1} windows, {2} tabs)">
                                    <Binding Path="Timestamp"/>
                                    <Binding Path="WindowCount"/>
                                    <Binding Path="TabCount"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Content="Clear" Margin="6,0,0,0" Padding="8,4" Click="ClearFilter_Click"/>
        </StackPanel>

        <!-- Results tree -->
        <TreeView Grid.Row="2" ItemsSource="{Binding Results}"
                  BorderThickness="1" Padding="4"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <TreeView.Resources>
                <!-- Snapshot level -->
                <HierarchicalDataTemplate DataType="{x:Type vm:SnapshotNode}" ItemsSource="{Binding Windows}">
                    <TextBlock Text="{Binding Display}" FontWeight="Bold" FontSize="13" Margin="0,2"/>
                </HierarchicalDataTemplate>

                <!-- Window level -->
                <HierarchicalDataTemplate DataType="{x:Type vm:WindowNode}" ItemsSource="{Binding Tabs}">
                    <TextBlock Text="{Binding Display}" FontSize="12.5" Margin="0,1"/>
                </HierarchicalDataTemplate>

                <!-- Tab level -->
                <HierarchicalDataTemplate DataType="{x:Type vm:TabNode}" ItemsSource="{Binding NavEntries}">
                    <TextBlock Text="{Binding Display}" FontSize="12" Foreground="#333" Margin="0,1"
                               TextTrimming="CharacterEllipsis" MaxWidth="800"/>
                </HierarchicalDataTemplate>

                <!-- Nav entry (leaf) -->
                <DataTemplate DataType="{x:Type vm:NavEntryNode}">
                    <TextBlock Text="{Binding Display}" FontSize="11" Foreground="#666"
                               TextTrimming="CharacterEllipsis" MaxWidth="750"/>
                </DataTemplate>
            </TreeView.Resources>

            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay, FallbackValue=False}"/>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>

        <!-- Status bar -->
        <Border Grid.Row="3" BorderThickness="0,1,0,0" BorderBrush="#DDD" Margin="0,4,0,0" Padding="0,4,0,0">
            <TextBlock Text="{Binding StatusText}" Foreground="#666" FontSize="11.5"/>
        </Border>
    </Grid>
</Window>
